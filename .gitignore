# OS / editor
.DS_Store
Thumbs.db
*.swp
.idea/
.vscode/

# Python (evaluation / generator scripts)
__pycache__/
*.pyc
.env
venv/

# Batch-evaluation intermediates (regenerated by evaluate_submissions.py prepare)
submissions/_eval-input-*.md
submissions-example/_eval-input-*.md

# Real participant submissions and their generated feedback are not committed by
# default (keep the folder + its README). The worked example lives in
# submissions-example/ and IS committed.
submissions/*
!submissions/README.md
